---
import BaseLayout from "layouts/BaseLayout.astro";
import FormManager from "forms/example-2/FormManager";

import "styles/pages/example.css";
import Tooltip from "components/tooltip/Tooltip";
---

<BaseLayout title="Road to MVP" description="Example of a form with Aphrodite Chibi">
  <main>
    <header>
      <h1>Tooltip playground</h1>
    </header>
    <section style="text-align: center;">
      <p>See how the new tooltip component behaves.</p>
      <Tooltip id="one" text="Im the first tooltip 🔴" client:visible/>
      <Tooltip id="two" text="Im the second tooltip 🔵" client:visible/>
    </section>
  </main>
</BaseLayout>
