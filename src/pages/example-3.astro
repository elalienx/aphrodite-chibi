---
import BaseLayout from "layouts/BaseLayout.astro";

import "styles/pages/example.css";
import Tooltip from "components/tooltip/Tooltip";
import TooltipPlus from "components/tooltip/Tooltip";
---

<BaseLayout title="Road to MVP" description="Example of a form with Aphrodite Chibi">
  <main>
    <header style="text-align: left;">
      <h1>Tooltip playground</h1>
      <p>See how the new tooltip component behaves.</p>
    </header> 

    <section>
      <h2>Tooltip positioning</h2>
      <h3>Top</h3>
      <TooltipPlus direction="bottom" client:visible/>
      
      <h3>Bottom</h3>
      <TooltipPlus direction="top" client:visible/>

      <h3>Left</h3>
      <TooltipPlus direction="right" client:visible/>
      
      <h3>Right</h3>
      <TooltipPlus direction="left" client:visible/>
    </section>
  </main>
</BaseLayout>
