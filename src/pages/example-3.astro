---
import BaseLayout from "layouts/BaseLayout.astro";

import "styles/pages/example.css";
import Tooltip from "components/tooltip/Tooltip";
---

<BaseLayout title="Road to MVP" description="Example of a form with Aphrodite Chibi">
  <main>
    <Tooltip id="one" text="There is no space at the top!" client:visible/>
    <header style="text-align: left;">
      <h1>Tooltip playground</h1>
      <p>See how the new tooltip component behaves.</p>
    </header>

    <section>
    <h2>Interactive tooltips</h2>
    <div style="display: flex; flex-direction: row; gap: var(--space-xl);">
      <Tooltip id="two" text="This is my default position" client:visible/>
    </div>
    </section>

