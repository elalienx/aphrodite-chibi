---
import RadioOptionComponent from "ui/components/radio-option/RadioOption";

import Documentation from "layouts/Documentation.astro";

const code = `
import RadioOption from "./RadioOption"

<RadioOption>I'm a radio</RadioOption>
`.trim();
---

<Documentation title="Radio option" code={code}>
  <div slot="description">
    <p>Individiual radio element.</p>
    <p>Use <code>RadioGroup</code> for a complete usable item.</p>
  </div>
  <RadioOptionComponent slot="component">
    I'm a radio option
  </RadioOptionComponent>
</Documentation>
